<nav class="noa-breadcrumb noa-breadcrumb--page" aria-label="Breadcrumb">
  <a href="{{ routes.root_url }}">Home</a>
  <span class="noa-breadcrumb__sep" aria-hidden="true">/</span>
  <span>{{ collection.title }}</span>
</nav>

{% section 'collection-banner' %}

<section class="product-index">
  <div class="section-head section-head--plain">
    <div>
      <p class="section-kicker">Shop</p>
      <h2 class="section-title">{{ collection.title }}</h2>
    </div>
  </div>

  <div class="collection-toolbar">
    <div class="collection-toolbar__filters">
      {%- assign type_handles = 'rings,earrings,necklaces,bracelets' | split: ',' -%}
      {%- assign extra_handles = 'signet-rings,gold-collection,sterling-silver,brass,mixed-metals,copper,desert-collection,coral,fold-forming,color-blocks,wires' | split: ',' -%}
      {%- assign is_type = false -%}
      {%- for h in type_handles -%}{%- if collection.handle == h -%}{%- assign is_type = true -%}{%- endif -%}{%- endfor -%}
      {%- assign is_extra = false -%}
      {%- for h in extra_handles -%}{%- if collection.handle == h -%}{%- assign is_extra = true -%}{%- endif -%}{%- endfor -%}

      <a class="collection-chip {% unless is_type or is_extra %}is-active{% endunless %}" href="{{ routes.all_products_collection_url }}">All</a>
      {%- for handle in type_handles -%}
        {%- assign fc = collections[handle] -%}
        {%- if fc -%}
          <a class="collection-chip {% if collection.handle == handle %}is-active{% endif %}" href="{{ fc.url }}">{{ fc.title }}</a>
        {%- endif -%}
      {%- endfor -%}

      {%- assign extra_label = 'Collections' -%}
      {%- for handle in extra_handles -%}
        {%- if collection.handle == handle -%}{%- assign extra_label = collections[handle].title -%}{%- endif -%}
      {%- endfor -%}
      <div class="collection-dropdown collection-dropdown--inline" id="CollectionDropdown">
        <button class="collection-dropdown__trigger {% if is_extra %}is-active{% endif %}" aria-haspopup="listbox" aria-expanded="false" aria-label="Filter by collection">
          <span>{{ extra_label }}</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <ul class="collection-dropdown__menu" role="listbox" aria-label="More collections">
          {%- for handle in extra_handles -%}
            {%- assign fc = collections[handle] -%}
            {%- if fc -%}
              <li role="option">
                <a class="collection-dropdown__option {% if collection.handle == handle %}is-selected{% endif %}" href="{{ fc.url }}">{{ fc.title }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>
    <div class="collection-toolbar__sort">
      {%- assign sort_label = 'Featured' -%}
      {%- if collection.sort_by == 'price-ascending' -%}{%- assign sort_label = 'Price: Low to high' -%}
      {%- elsif collection.sort_by == 'price-descending' -%}{%- assign sort_label = 'Price: High to low' -%}
      {%- elsif collection.sort_by == 'title-ascending' -%}{%- assign sort_label = 'A–Z' -%}
      {%- endif -%}
      <div class="sort-dropdown" id="SortDropdown">
        <button class="sort-dropdown__trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Sort by">
          <span class="sort-dropdown__label">{{ sort_label }}</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <ul class="sort-dropdown__menu" role="listbox" aria-label="Sort options">
          <li class="sort-dropdown__option {% if collection.sort_by == 'manual' or collection.sort_by == blank %}is-selected{% endif %}" role="option" data-url="{{ collection.url }}?sort_by=manual">Featured</li>
          <li class="sort-dropdown__option {% if collection.sort_by == 'price-ascending' %}is-selected{% endif %}" role="option" data-url="{{ collection.url }}?sort_by=price-ascending">Price: Low to high</li>
          <li class="sort-dropdown__option {% if collection.sort_by == 'price-descending' %}is-selected{% endif %}" role="option" data-url="{{ collection.url }}?sort_by=price-descending">Price: High to low</li>
          <li class="sort-dropdown__option {% if collection.sort_by == 'title-ascending' %}is-selected{% endif %}" role="option" data-url="{{ collection.url }}?sort_by=title-ascending">A–Z</li>
        </ul>
      </div>
    </div>
  </div>

  {% if collection.description != blank %}
    <div class="rte collection-description">{{ collection.description }}</div>
  {% endif %}

  {% if collection.products_count > 0 %}
    {% paginate collection.products by 12 %}
      <div class="product-grid">
        {% for product in collection.products %}
          {% render 'product-card', product: product, collection_title: collection.title, show_badge: forloop.first %}
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="pagination" aria-label="Pagination">
          {% if paginate.previous %}
            <a class="button button--text" href="{{ paginate.previous.url }}">← Previous</a>
          {% endif %}
          <span class="pagination__count">Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
          {% if paginate.next %}
            <a class="button button--text" href="{{ paginate.next.url }}">Next →</a>
          {% endif %}
        </nav>
      {% endif %}
    {% endpaginate %}
  {% else %}
    <p class="cart-empty">{{ 'collections.general.no_matches' | t }}</p>
  {% endif %}
</section>

<script>
(function () {
  var dd = document.getElementById('SortDropdown');
  if (!dd) return;
  var trigger = dd.querySelector('.sort-dropdown__trigger');
  var options = dd.querySelectorAll('.sort-dropdown__option');

  trigger.addEventListener('click', function (e) {
    e.stopPropagation();
    var open = dd.classList.toggle('is-open');
    trigger.setAttribute('aria-expanded', String(open));
  });

  options.forEach(function (opt) {
    opt.addEventListener('click', function () {
      var url = opt.getAttribute('data-url');
      if (url) window.location.href = url;
    });
  });

  document.addEventListener('click', function () {
    dd.classList.remove('is-open');
    trigger.setAttribute('aria-expanded', 'false');
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      dd.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      trigger.focus();
    }
  });
})();

(function () {
  var cd = document.getElementById('CollectionDropdown');
  if (!cd) return;
  var trigger = cd.querySelector('.collection-dropdown__trigger');

  trigger.addEventListener('click', function (e) {
    e.stopPropagation();
    var open = cd.classList.toggle('is-open');
    trigger.setAttribute('aria-expanded', String(open));
  });

  document.addEventListener('click', function () {
    cd.classList.remove('is-open');
    trigger.setAttribute('aria-expanded', 'false');
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      cd.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
      trigger.focus();
    }
  });
})();
</script>
