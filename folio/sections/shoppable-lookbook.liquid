{% comment %}
  sections/shoppable-lookbook.liquid
  "Shop the Look" shoppable image section — homepage, above footer
{% endcomment %}

{%- style -%}
  #shopify-section-{{ section.id }} .shoppable-lookbook__image-wrap {
    min-height: {{ section.settings.section_height }};
  }
{%- endstyle -%}

<div class="shoppable-lookbook">
  {%- if section.settings.kicker != blank or section.settings.heading != blank -%}
    <div class="shoppable-lookbook__head">
      {%- if section.settings.kicker != blank -%}
        <p class="section-kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="shoppable-lookbook__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="shoppable-image shoppable-lookbook__image-wrap">
    {%- assign lkbk_image = section.settings.image -%}

    {%- if lkbk_image -%}
      {{
        lkbk_image
        | image_url: width: 1800
        | image_tag:
          class: 'shoppable-image__media',
          loading: 'lazy',
          widths: '800, 1200, 1600, 1800',
          sizes: '100vw',
          alt: lkbk_image.alt
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'shoppable-image__media shoppable-image__placeholder' }}
    {%- endif -%}

    {%- for block in section.blocks -%}
      {%- if block.type == 'hotspot' -%}
        {%- render 'shoppable-hotspot', block: block -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Shop the Look",
  "tag": "section",
  "class": "shoppable-lookbook-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "On Instagram"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Studio moments & new pieces — @noa.shechter"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        { "value": "60vh", "label": "Medium (60vh)" },
        { "value": "75vh", "label": "Large (75vh)" },
        { "value": "90vh", "label": "Full (90vh)" }
      ],
      "default": "75vh"
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "limit": 5,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "x_position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Horizontal position",
          "default": 50
        },
        {
          "type": "range",
          "id": "y_position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "label": "Vertical position",
          "default": 50
        },
        {
          "type": "select",
          "id": "tooltip_style",
          "label": "Tooltip style",
          "options": [
            { "value": "card", "label": "Card (image + price + CTA)" },
            { "value": "compact", "label": "Compact (one-line)" }
          ],
          "default": "card"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop the Look",
      "blocks": [
        { "type": "hotspot" }
      ]
    }
  ]
}
{% endschema %}
