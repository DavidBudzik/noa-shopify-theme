{%- comment -%}
  Slide blocks drive the slideshow. Fallback to single asset image when no slides set.
{%- endcomment -%}

{% assign slide_blocks = section.blocks | where: "type", "slide" %}
{% assign hotspot_blocks = section.blocks | where: "type", "hotspot" %}

{% assign banner_title = collection.title %}
{% if section.settings.heading_override != blank %}
  {% assign banner_title = section.settings.heading_override %}
{% endif %}

{% assign banner_kicker = settings.collection_heading_prefix | default: 'Browse the' %}
{% if section.settings.kicker_override != blank %}
  {% assign banner_kicker = section.settings.kicker_override %}
{% endif %}

{%- comment -%}
  Priority: collection.image (set per-collection in Shopify admin) →
            handle-based asset fallback → section.settings.image (global override)
{%- endcomment -%}
{% assign fallback_url = blank %}
{% if slide_blocks.size == 0 %}
  {% if collection.image != blank %}
    {% assign fallback_image = collection.image %}
  {% elsif section.settings.image != blank %}
    {% assign fallback_image = section.settings.image %}
  {% endif %}
  {% unless fallback_image %}
    {%- comment -%}
      Only handles with a bundled asset are mapped. Unknown collections fall
      through with a blank fallback_url so no broken &lt;img&gt; is rendered —
      the overlay title still shows. Set collection.image in admin for others.
    {%- endcomment -%}
    {% case collection.handle %}
      {% when 'rings' %}
        {% assign fallback_url = 'collection-banner-rings.png' | asset_url %}
      {% when 'earrings' %}
        {% assign fallback_url = 'collection-banner-earrings.png' | asset_url %}
      {% when 'necklaces' %}
        {% assign fallback_url = 'collection-banner-necklaces.png' | asset_url %}
      {% when 'bracelets' %}
        {% assign fallback_url = 'collection-banner-bracelets.png' | asset_url %}
    {% endcase %}
  {% endunless %}
{% endif %}

{%- style -%}
  #shopify-section-{{ section.id }} .collection-banner__inner {
    aspect-ratio: unset;
    height: 320px;
  }
  #shopify-section-{{ section.id }} .shoppable-image {
    height: 100%;
  }
{%- endstyle -%}

<div class="collection-banner">
  <div class="collection-banner__inner">
    <div class="shoppable-image">

      {% if slide_blocks.size > 0 %}
        <div class="banner-slides" data-banner-slides>
          {%- for block in slide_blocks -%}
            <div class="banner-slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                {%- if forloop.first -%}{%- assign slide_loading = 'eager' -%}{%- else -%}{%- assign slide_loading = 'lazy' -%}{%- endif -%}
                {{
                  block.settings.image
                  | image_url: width: 1800
                  | image_tag:
                    loading: slide_loading,
                    widths: '720, 1200, 1800',
                    sizes: 'min(85rem, 100vw)',
                    class: 'collection-banner__img',
                    alt: banner_title
                }}
              {% endif %}
            </div>
          {%- endfor -%}
        </div>

      {% elsif fallback_image %}
        {{
          fallback_image
          | image_url: width: 1800
          | image_tag:
            loading: 'eager',
            widths: '720, 1200, 1800',
            sizes: 'min(85rem, 100vw)',
            class: 'collection-banner__img',
            alt: banner_title
        }}
      {% elsif fallback_url != blank %}
        {%- comment -%}theme-check-disable RemoteAsset{%- endcomment -%}
        <img class="collection-banner__img"
          src="{{ fallback_url }}"
          alt="{{ banner_title }}"
          loading="eager"
          width="1800"
          height="600">
        {%- comment -%}theme-check-enable RemoteAsset{%- endcomment -%}
      {% endif %}

      {%- for block in hotspot_blocks -%}
        {%- render 'shoppable-hotspot', block: block -%}
      {%- endfor -%}
    </div>

    <div class="collection-banner__overlay">
      <p class="section-kicker">{{ banner_kicker }}</p>
      <h1 class="collection-banner__title">{{ banner_title }}</h1>
    </div>

    {% if slide_blocks.size > 1 %}
      <button class="collection-banner__nav collection-banner__nav--prev" data-banner-prev aria-label="Previous banner">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M13 16L7 10L13 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </button>
      <button class="collection-banner__nav collection-banner__nav--next" data-banner-next aria-label="Next banner">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
        </svg>
      </button>
    {% endif %}
  </div>
</div>

{% if slide_blocks.size > 1 %}
<script>
(function() {
  var inner = document.getElementById('shopify-section-{{ section.id }}');
  if (!inner) return;
  var slides = inner.querySelectorAll('[data-banner-slides] .banner-slide');
  if (!slides.length) return;
  var current = 0;

  function goTo(idx) {
    slides[current].classList.remove('is-active');
    current = (idx + slides.length) % slides.length;
    slides[current].classList.add('is-active');
  }

  inner.querySelector('[data-banner-prev]').addEventListener('click', function() { goTo(current - 1); });
  inner.querySelector('[data-banner-next]').addEventListener('click', function() { goTo(current + 1); });
})();
</script>
{% endif %}

{% schema %}
{
  "name": "Collection banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback image (used when no slides added)"
    },
    {
      "type": "text",
      "id": "heading_override",
      "label": "Heading override (leave blank to use collection title)"
    },
    {
      "type": "text",
      "id": "kicker_override",
      "label": "Kicker override (leave blank for default)"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Banner slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" }
      ]
    },
    {
      "type": "hotspot",
      "name": "Hotspot",
      "limit": 5,
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "range", "id": "x_position", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Horizontal position", "default": 50 },
        { "type": "range", "id": "y_position", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Vertical position", "default": 50 }
      ]
    }
  ],
  "presets": [{ "name": "Collection banner" }]
}
{% endschema %}
