<section class="hero-panel">
  {%- style -%}
    #shopify-section-{{ section.id }} .hero-panel {
      height: {{ section.settings.section_height | default: '100svh' }};
      min-height: 34rem;
    }
  {%- endstyle -%}

  <div class="shoppable-image">
    <div class="hero-media">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1800
          | image_tag:
            loading: 'eager',
            widths: '720, 960, 1280, 1800',
            sizes: '100vw',
            class: 'hero-image-media',
            alt: section.settings.title,
            style: 'position:absolute;inset:0;width:100%;height:100%;object-fit:cover;'
        }}
      {% else %}
        <img
          class="hero-image-media"
          src="{{ 'home-page-hero-hot-spots.jpeg' | asset_url }}"
          alt="{{ section.settings.title }}"
          loading="eager"
          width="2560"
          height="1463"
          style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;">
      {% endif %}
    </div>
    {%- for block in section.blocks -%}
      {%- if block.type == 'hotspot' -%}
        {%- render 'shoppable-hotspot', block: block -%}
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="hero-copy">
    {% if section.settings.eyebrow != blank %}
      <p class="section-kicker">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.title != blank %}
      <h1 class="hero-title">{{ section.settings.title }}</h1>
    {% endif %}
    {% if section.settings.text != blank %}
      <p class="hero-text">{{ section.settings.text }}</p>
    {% endif %}
    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="hero-actions">
        <a class="button button--solid" href="{{ section.settings.button_link }}">{{ section.settings.button_label }}</a>
        {% if section.settings.button_label_two != blank and section.settings.button_link_two != blank %}
          <a class="button button--ghost" href="{{ section.settings.button_link_two }}">{{ section.settings.button_label_two }}</a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  {% if section.settings.show_scroll_cue %}
    <div class="hero-scroll" aria-hidden="true">
      <span>Scroll</span>
      <svg viewBox="0 0 16 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8 3v15M3 13l5 5 5-5"/>
      </svg>
    </div>
  {% endif %}
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "New in the studio" },
    { "type": "text", "id": "title", "label": "Title", "default": "Unisex jewelry, made by hand in Tel Aviv." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Quiet forms, mixed metals, and one-of-a-kind pieces. Hand-finished in the studio on Nahalat Binyamin." },
    { "type": "text", "id": "button_label", "label": "Primary button label", "default": "Shop the collection" },
    { "type": "url", "id": "button_link", "label": "Primary button link" },
    { "type": "text", "id": "button_label_two", "label": "Secondary button label", "default": "The studio" },
    { "type": "url", "id": "button_link_two", "label": "Secondary button link" },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        { "value": "70vh", "label": "Medium (70vh)" },
        { "value": "85vh", "label": "Tall (85vh)" },
        { "value": "100svh", "label": "Full screen" }
      ],
      "default": "100svh"
    },
    { "type": "checkbox", "id": "show_scroll_cue", "label": "Show scroll indicator", "default": true }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Hotspot",
      "limit": 5,
      "settings": [
        { "type": "product", "id": "product", "label": "Product" },
        { "type": "range", "id": "x_position", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Horizontal position", "default": 50 },
        { "type": "range", "id": "y_position", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Vertical position", "default": 50 }
      ]
    }
  ],
  "presets": [{ "name": "Hero" }]
}
{% endschema %}
